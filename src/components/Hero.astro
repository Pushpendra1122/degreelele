---
import { courses } from "../data/courses";
---

<section class="relative isolate min-h-[calc(100vh-5rem)] overflow-hidden bg-brand-navy text-white">
  <img
    src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=2400&q=85"
    alt="Students studying together with laptops and notebooks"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-navy via-brand-navy/88 to-brand-blue/60"></div>
  <div class="container-page grid min-h-[calc(100vh-5rem)] gap-12 py-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
    <div>
      <p class="mb-5 text-base font-bold uppercase tracking-wide text-amber-200">Degreelele education information</p>
      <h1 class="max-w-5xl text-5xl font-black leading-[1.04] text-white md:text-7xl xl:text-8xl">Explore Distance, Online & Regular Degree Courses</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-slate-100 md:text-2xl md:leading-10">Degreelele helps students find course and university information in one simple place. Compare available programmes, duration, eligibility, and learning modes.</p>
      <div class="mt-9 max-w-3xl rounded-lg border border-white/20 bg-white/10 p-3 backdrop-blur">
        <div class="rounded-md bg-white px-5 py-5 text-lg text-slate-500 shadow-sm">Search course, university or programme</div>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        {courses.map((course) => <a href={`/courses/${course.slug}`} class="badge">{course.name}</a>)}
      </div>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href="/courses" class="rounded-md bg-brand-gold px-7 py-4 text-lg font-bold text-brand-navy hover:bg-amber-300 hover:text-brand-navy">Explore Courses</a>
        <a href="/universities" class="rounded-md border border-white px-7 py-4 text-lg font-bold text-white hover:bg-white hover:text-brand-navy">View Universities</a>
      </div>
    </div>
    <div class="grid gap-5 lg:justify-self-end">
      <figure class="overflow-hidden rounded-lg border border-white/20 bg-white/10 shadow-2xl backdrop-blur">
        <img
          src="https://images.unsplash.com/photo-1513258496099-48168024aec0?auto=format&fit=crop&w=1200&q=85"
          alt="Student learning online with study notes"
          class="aspect-[4/3] w-full object-cover"
        />
        <figcaption class="p-7">
          <p class="text-base font-bold uppercase tracking-wide text-amber-200">Featured listing</p>
          <h2 class="mt-3 text-4xl font-black text-white">Subharti University</h2>
          <p class="mt-4 text-lg leading-8 text-slate-100">Distance education course information for UG and PG programmes including BA, B.Com, BBA, BCA, MA, M.Com, MBA, MCA and M.Sc.</p>
        </figcaption>
      </figure>
      <div class="grid grid-cols-2 gap-4 text-base font-semibold">
        <span class="rounded-md bg-white/15 p-4 backdrop-blur">Meerut</span>
        <span class="rounded-md bg-white/15 p-4 backdrop-blur">Distance Mode</span>
        <span class="rounded-md bg-white/15 p-4 backdrop-blur">UG Courses</span>
        <span class="rounded-md bg-white/15 p-4 backdrop-blur">PG Courses</span>
      </div>
    </div>
  </div>
</section>

<section class="bg-white">
  <div class="container-page grid gap-5 py-8 md:grid-cols-3">
    {[
      ["https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=900&q=80", "Students walking on a campus", "University-wise course information"],
      ["https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=900&q=80", "Laptop showing online learning", "Distance and online education"],
      ["https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&w=900&q=80", "Teacher helping learners", "Simple guidance for students"],
    ].map(([src, alt, title]) => (
      <article class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-soft">
        <img src={src} alt={alt} class="h-52 w-full object-cover" />
        <div class="p-5">
          <h2 class="text-xl font-bold text-brand-navy">{title}</h2>
        </div>
      </article>
    ))}
  </div>
</section>
