---
import type { Course } from "../data/courses";

const { rows } = Astro.props as { rows: Course[] };
---

<div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
    <thead class="bg-brand-navy text-white">
      <tr>
        <th class="px-4 py-3 font-semibold">Course</th>
        <th class="px-4 py-3 font-semibold">Full Name</th>
        <th class="px-4 py-3 font-semibold">Level</th>
        <th class="px-4 py-3 font-semibold">Duration</th>
        <th class="px-4 py-3 font-semibold">Mode</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {rows.map((course) => (
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-3 font-bold text-brand-navy">{course.name}</td>
          <td class="px-4 py-3">{course.fullName}</td>
          <td class="px-4 py-3">{course.level === "Postgraduate" ? "PG" : "UG"}</td>
          <td class="px-4 py-3">{course.duration}</td>
          <td class="px-4 py-3">Distance</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
