---
const { eyebrow, title, subtitle } = Astro.props;
---

<div class="mb-8 max-w-3xl">
  {eyebrow && <p class="mb-2 text-base font-bold uppercase tracking-wide text-brand-blue">{eyebrow}</p>}
  <h2 class="text-4xl font-bold text-brand-ink md:text-5xl">{title}</h2>
  {subtitle && <p class="mt-4 text-xl leading-9 text-slate-600">{subtitle}</p>}
</div>
