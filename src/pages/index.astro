---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CourseCard from "../components/CourseCard.astro";
import UniversityCard from "../components/UniversityCard.astro";
import DisclaimerBox from "../components/DisclaimerBox.astro";
import { courses } from "../data/courses";
import { universities } from "../data/universities";
---

<BaseLayout>
  <Hero />
  <section class="container-page py-14">
    <SectionTitle title="Popular Courses" subtitle="Explore common undergraduate and postgraduate programmes with duration, level and university links." />
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {courses.map((course) => <CourseCard course={course} />)}
    </div>
  </section>
  <section class="bg-white py-14">
    <div class="container-page">
      <SectionTitle title="Featured University" subtitle="University-wise course information for students comparing flexible learning options." />
      <UniversityCard university={universities[0]} />
      <div class="mt-5"><DisclaimerBox text="Students should verify university recognition and programme approval from official UGC-DEB sources before admission." /></div>
    </div>
  </section>
  <section class="container-page py-14">
    <SectionTitle title="Why Degreelele" subtitle="Simple education information before you make a course or university decision." />
    <div class="grid gap-5 md:grid-cols-4">
      {[
        ["Course Information", "Find details about popular UG and PG programmes."],
        ["University-Wise Details", "Explore which courses are available in each university."],
        ["Distance & Online Education", "Understand flexible learning options for students and working professionals."],
        ["Simple Guidance", "Get information in easy language before making a decision."],
      ].map(([title, text]) => <article class="surface p-5"><h3 class="font-bold text-brand-navy">{title}</h3><p class="mt-2 text-sm leading-7 text-slate-600">{text}</p></article>)}
    </div>
  </section>
  <section class="bg-white py-14">
    <div class="container-page">
      <SectionTitle title="Learning Modes" />
      <div class="grid gap-5 md:grid-cols-3">
        {[
          ["Distance Education", "Flexible study mode where students can continue education without attending regular daily classes."],
          ["Online Education", "Technology-supported learning with digital classes, LMS, and online study material."],
          ["Regular Education", "Traditional campus-based education with classroom learning."],
        ].map(([title, text]) => <article class="surface p-6"><h3 class="text-xl font-bold text-brand-navy">{title}</h3><p class="mt-3 leading-7 text-slate-600">{text}</p></article>)}
      </div>
      <div class="mt-8"><DisclaimerBox /></div>
    </div>
  </section>
</BaseLayout>
