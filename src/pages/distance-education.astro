---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import SectionTitle from "../components/SectionTitle.astro";
import DisclaimerBox from "../components/DisclaimerBox.astro";
import { courses } from "../data/courses";
---

<BaseLayout title="Distance Education - Degreelele" description="Distance education information, popular courses, who can consider it and important verification points.">
  <Breadcrumb items={[{ label: "Distance Education" }]} />
  <section class="container-page py-10">
    <h1 class="text-4xl font-black text-brand-navy md:text-5xl">Distance Education</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">Distance education is a flexible learning mode where students can continue their studies without attending regular daily classroom sessions. It can be useful for working professionals, students who cannot relocate, and learners who want flexible study options.</p>
  </section>
  <section class="container-page grid gap-8 pb-16 md:grid-cols-3">
    <article class="surface p-6 md:col-span-2">
      <SectionTitle title="Who Can Consider Distance Education?" />
      <div class="grid gap-3 sm:grid-cols-2">
        {["Working professionals", "Students who missed regular college", "Students living far from campus", "Learners who want flexible study timing", "Students continuing education with job or family responsibility"].map((item) => <div class="rounded-md bg-slate-100 p-4 font-semibold text-brand-navy">{item}</div>)}
      </div>
    </article>
    <article class="surface p-6">
      <SectionTitle title="Popular Courses" />
      <div class="flex flex-wrap gap-2">{courses.map((course) => <a href={`/courses/${course.slug}`} class="badge">{course.name}</a>)}</div>
    </article>
    <div class="md:col-span-3"><DisclaimerBox text="Before choosing any distance education programme, students should verify the university recognition, programme approval, fee structure, examination process, and admission rules from official university and UGC-DEB sources." /></div>
  </section>
</BaseLayout>
